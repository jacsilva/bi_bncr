    u.regiao,
    i.fase,
    i.data_entrada_fase,
    i.processo_sei,
    i.ponto_focal,
    i.observacao,

    -- coluna calculada
    (current_date - i.data_entrada_fase)   as dias_na_fase
from integracao i
left join "sinesp_ppe"."staging"."dim_uf" u
    on i.uf = u.uf
  );
