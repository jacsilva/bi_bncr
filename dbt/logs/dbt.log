  create view "sinesp_ppe"."staging"."stg_procedimento__dbt_tmp"
    
    
  as (
    -- Camada STAGING: extrai/normaliza campos do JSONB da fonte bruta.
-- Primeiro estágio: usa source().

with origem as (

    select
        id_procedimento,
        dados,
        importado_em
    from "sinesp_ppe"."public"."procedimento"

)

select
    id_procedimento,
    (dados ->> 'NR_REGISTRO')::bigint            as nr_registro,
    (dados ->> 'AN_REGISTRO')::int               as an_registro,
    dados ->> 'SG_UF_REGISTRO'                    as sg_uf_registro,
    dados ->> 'IN_TIPO_PROCEDIMENTO'             as in_tipo_procedimento,
    dados ->> 'IN_SITUACAO_ATUAL'               as in_situacao_atual,
    dados ->> 'TP_FORCA_ORIGEM'                  as tp_forca_origem,
    nullif(dados ->> 'ID_PROCEDIMENTO_PAI', '')::bigint    as id_procedimento_pai,
    nullif(dados ->> 'ID_PROCEDIMENTO_ADITADO', '')::bigint as id_procedimento_aditado,
    (dados ->> 'SN_SIGILOSO')::int               as sn_sigiloso,
    -- DT_REGISTRO vem como '2026-06-11T15:56:25.262_America/Fortaleza'
    split_part(dados ->> 'DT_REGISTRO', '_', 1)::timestamp as dt_registro,
    importado_em
from origem
  );
