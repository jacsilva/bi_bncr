  create view "sinesp_ppe"."staging"."int_procedimento__dbt_tmp"
    
    
  as (
    -- Camada INTERMEDIATE: regras de negócio/derivações sobre o staging.
-- Estágios seguintes: usam ref().

with stg as (

    select * from "sinesp_ppe"."staging"."stg_procedimento"

)

select
    id_procedimento,
    nr_registro,
